# Database - Neon Postgres via Vercel Marketplace
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI (optional — only needed for AI audit generation)
OPENAI_API_KEY=sk-...

# App secret for session signing (generate with: openssl rand -base64 32)
APP_SECRET=your-secret-here

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override the seeded admin account (recommended for production).
# The admin password is re-applied from ADMIN_PASSWORD on every seed/deploy,
# so set this to rotate it. Defaults to admin@agencyleadradar.com / admin123.
ADMIN_EMAIL=admin@agencyleadradar.com
ADMIN_PASSWORD=admin123

# Optional future variables
# PAGESPEED_API_KEY=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
